# Sample SPARQL queries against graph/docs_graph.ttl
# Run: python3 scripts/query.py "<query>"   or load into ABI/Oxigraph.

# 1. Which tasks depend on the concept of a StatefulSet?
#    (tasks mentioning the term, plus what those tasks reference)
PREFIX docs: <http://docsbot.local/ontology/>
PREFIX term: <http://docsbot.local/term/>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?title ?path WHERE {
  ?t a docs:TaskTopic ;
     docs:mentions term:statefulset ;
     dcterms:title ?title ;
     docs:canonicalPath ?path .
}

