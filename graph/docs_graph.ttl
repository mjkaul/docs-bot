@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix docs: <http://docsbot.local/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix subject: <http://docsbot.local/subject/> .
@prefix term: <http://docsbot.local/term/> .
@prefix topic: <http://docsbot.local/topic/> .

docs: a owl:Ontology ;
    rdfs:label "docs_bot Documentation Ontology" ;
    dcterms:license "Code: MIT. Instance content derives from Kubernetes docs, CC-BY 4.0." ;
    rdfs:comment """Application-level ontology for documentation topics, aligned with
    BFO (ISO/IEC 21838-2) via Common Core Ontologies so it composes with the Naas ABI
    ontology stack. Topics are information content entities; subjects form a SKOS
    concept scheme (the taxonomy facet)."""@en .

docs:ReferenceTopic a owl:Class ;
    rdfs:label "Reference Topic" ;
    rdfs:comment "Lookup material; specifications and APIs (DITA reference)." ;
    rdfs:subClassOf docs:DocumentationTopic .

docs:canonicalPath a owl:DatatypeProperty ;
    rdfs:label "canonical path" ;
    rdfs:domain docs:DocumentationTopic .

docs:defines a owl:ObjectProperty ;
    rdfs:label "defines" ;
    rdfs:domain docs:GlossaryEntry ;
    rdfs:range docs:Term .

docs:hasSubject a owl:ObjectProperty ;
    rdfs:label "has subject" ;
    rdfs:domain docs:DocumentationTopic ;
    rdfs:range docs:Subject .

docs:mentions a owl:ObjectProperty ;
    rdfs:label "mentions" ;
    rdfs:comment "Topic body explicitly references this vocabulary term." ;
    rdfs:domain docs:DocumentationTopic ;
    rdfs:range docs:Term .

docs:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of" ;
    rdfs:comment "Topic belongs to a section. Transitive: enables hierarchy inferencing." ;
    rdfs:domain docs:DocumentationTopic ;
    rdfs:range docs:SectionTopic .

docs:references a owl:ObjectProperty ;
    rdfs:label "references" ;
    rdfs:comment "Hyperlink from one topic to another." ;
    rdfs:domain docs:DocumentationTopic ;
    rdfs:range docs:DocumentationTopic .

docs:topicId a owl:DatatypeProperty ;
    rdfs:label "topic id" ;
    rdfs:domain docs:DocumentationTopic .

topic:data.aggregating-data a docs:TaskTopic ;
    docs:canonicalPath "/en/latest/data/aggregating-data" ;
    docs:hasSubject subject:data ;
    docs:mentions term:dataset ;
    docs:topicId "data.aggregating-data" ;
